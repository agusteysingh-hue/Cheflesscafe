  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0A0806">
  <title>
    <%= title %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    body {
      background: #0A0806;
    }

    .checkout-page {
      min-height: 100vh;
      padding: 64px 16px 48px;
      display: grid;
      place-items: start center;
    }

    .checkout-grid {
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 28px;
      max-width: 900px;
      width: 100%;
      margin: 0 auto;
      align-items: start;
    }

    /* ── LEFT PANEL: Social proof & value ── */
    .checkout-left {}

    .co-brand {
      font-family: var(--font-display);
      font-size: 32px;
      color: var(--amber);
      letter-spacing: 0.04em;
      margin-bottom: 4px;
    }

    .co-tagline {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 24px;
    }

    /* Mini headline */
    .co-headline {
      font-family: var(--font-display);
      font-size: clamp(28px, 4vw, 42px);
      color: var(--white);
      line-height: 1.05;
      margin-bottom: 12px;
    }

    .co-headline span {
      color: var(--amber);
    }

    .co-sub {
      font-size: 14px;
      color: var(--cream2);
      line-height: 1.6;
      margin-bottom: 24px;
    }

    /* What you get list */
    .co-includes {
      background: rgba(22, 19, 16, 0.7);
      border: 1px solid rgba(232, 146, 26, 0.1);
      border-radius: var(--radius-lg);
      padding: 20px;
      margin-bottom: 20px;
    }

    .co-includes-title {
      font-size: 11px;
      font-weight: 800;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 14px;
    }

    .co-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 8px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      font-size: 13px;
      color: var(--cream2);
    }

    .co-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .co-item-icon {
      font-size: 18px;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .co-item-text strong {
      color: var(--white);
      display: block;
      font-size: 13px;
      margin-bottom: 1px;
    }

    .co-item-text span {
      font-size: 11px;
      color: var(--muted);
    }

    /* Testimonial */
    .co-testi {
      background: rgba(232, 146, 26, 0.04);
      border: 1px solid rgba(232, 146, 26, 0.12);
      border-radius: var(--radius);
      padding: 16px 18px;
      margin-bottom: 16px;
    }

    .co-testi-stars {
      color: var(--amber);
      font-size: 14px;
      margin-bottom: 8px;
    }

    .co-testi-text {
      font-size: 13px;
      color: var(--cream2);
      line-height: 1.6;
      font-style: italic;
      margin-bottom: 10px;
    }

    .co-testi-author {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .co-testi-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--amber-dark), var(--amber));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 800;
      color: var(--dark);
      flex-shrink: 0;
    }

    .co-testi-name {
      font-size: 12px;
      font-weight: 700;
      color: var(--cream);
    }

    .co-testi-role {
      font-size: 10px;
      color: var(--muted);
    }

    /* ── RIGHT PANEL: Form ── */
    .checkout-right {
      position: sticky;
      top: 72px;
    }

    .co-form-card {
      background: rgba(22, 19, 16, 0.95);
      border: 1px solid rgba(232, 146, 26, 0.12);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
    }

    /* Price header */
    .co-price-header {
      background: linear-gradient(135deg, #1A1410, #201A12);
      border-bottom: 1px solid rgba(232, 146, 26, 0.1);
      padding: 20px 24px;
      text-align: center;
    }

    .co-off-pill {
      display: inline-block;
      background: rgba(34, 197, 94, 0.15);
      border: 1px solid rgba(34, 197, 94, 0.25);
      color: #69f0ae;
      font-size: 12px;
      font-weight: 800;
      padding: 4px 14px;
      border-radius: 100px;
      margin-bottom: 10px;
    }

    .co-price-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 4px;
    }

    .co-price-orig {
      font-size: 18px;
      color: var(--muted);
      text-decoration: line-through;
    }

    .co-price-main {
      font-family: var(--font-display);
      font-size: 56px;
      color: var(--amber);
      line-height: 1;
    }

    .co-price-note {
      font-size: 11px;
      color: var(--muted);
    }

    /* Countdown */
    .co-countdown {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-top: 12px;
      background: rgba(239, 68, 68, 0.06);
      border: 1px solid rgba(239, 68, 68, 0.15);
      border-radius: 8px;
      padding: 8px 14px;
    }

    .co-countdown-label {
      font-size: 11px;
      color: #EF9F9F;
      font-weight: 700;
    }

    .co-cd-time {
      font-family: var(--font-display);
      font-size: 18px;
      color: #EF4444;
      letter-spacing: 0.05em;
    }

    /* Form body */
    .co-form-body {
      padding: 22px 24px;
    }

    .co-step-label {
      font-size: 10px;
      font-weight: 800;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .co-step-dot {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--amber);
      color: var(--dark);
      font-size: 10px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Input with icon */
    .co-input-wrap {
      position: relative;
      margin-bottom: 14px;
    }

    .co-input-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
      line-height: 1;
    }

    .co-input {
      width: 100%;
      padding: 14px 14px 14px 42px;
      background: var(--dark3);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: var(--radius);
      color: var(--cream);
      font-size: 14px;
      font-family: var(--font-body);
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }

    .co-input:focus {
      border-color: rgba(232, 146, 26, 0.4);
      box-shadow: 0 0 0 3px rgba(232, 146, 26, 0.08);
    }

    .co-input::placeholder {
      color: var(--muted2);
    }

    /* Pay button */
    .co-pay-btn {
      width: 100%;
      padding: 17px;
      background: linear-gradient(135deg, #E8921A, #B86F0A);
      color: var(--dark);
      font-weight: 900;
      font-size: 16px;
      border: none;
      border-radius: var(--radius);
      cursor: pointer;
      font-family: var(--font-body);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: all 0.3s ease;
      box-shadow: 0 4px 24px rgba(232, 146, 26, 0.3);
      position: relative;
      overflow: hidden;
    }

    .co-pay-btn::after {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.12), transparent);
      animation: shimmer 2s infinite;
    }

    @keyframes shimmer {
      to {
        left: 100%;
      }
    }

    .co-pay-btn:hover {
      box-shadow: 0 6px 32px rgba(232, 146, 26, 0.45);
      transform: translateY(-1px);
    }

    .co-pay-btn:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none;
    }

    .co-pay-btn:disabled::after {
      display: none;
    }

    /* Microcopy under button */
    .co-secure-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-top: 12px;
      flex-wrap: wrap;
    }

    .co-secure-item {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 10px;
      color: var(--muted);
      font-weight: 600;
    }

    /* Social proof bar */
    .co-social-proof {
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .co-avatars {
      display: flex;
    }

    .co-av {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      border: 2px solid var(--dark2);
      background: linear-gradient(135deg, var(--amber-dark), var(--amber));
      color: var(--dark);
      font-size: 8px;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: -6px;
    }

    .co-av:first-child {
      margin-left: 0;
    }

    .co-social-text {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.4;
    }

    .co-social-text strong {
      color: var(--amber);
    }

    /* Error */
    .co-error {
      display: none;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      color: #EF9F9F;
      padding: 12px 14px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 14px;
    }

    /* Spinner */
    .co-spinner {
      width: 20px;
      height: 20px;
      border: 3px solid transparent;
      border-top-color: var(--dark);
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      display: none;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    /* ── Course Catalogue (Checkout) ── */
    .co-catalogue {
      background: rgba(22, 19, 16, 0.7);
      border: 1px solid rgba(232, 146, 26, 0.12);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-bottom: 20px;
    }

    /* Hidden by default — shown only in mobile media query */
    .co-catalogue-mobile {
      display: none;
    }

    .co-catalogue-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 18px;
      cursor: pointer;
      user-select: none;
      transition: background 0.2s;
    }

    .co-catalogue-header:hover {
      background: rgba(232, 146, 26, 0.05);
    }

    .co-catalogue-title {
      font-size: 11px;
      font-weight: 800;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .co-catalogue-title span {
      background: rgba(232, 146, 26, 0.12);
      border: 1px solid rgba(232, 146, 26, 0.2);
      color: var(--amber);
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 100px;
    }

    .co-cat-chevron {
      color: var(--muted);
      font-size: 14px;
      transition: transform 0.3s;
    }

    .co-cat-chevron.open {
      transform: rotate(180deg);
    }

    .co-catalogue-body {
      display: none;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
    }

    .co-catalogue-body.open {
      display: block;
    }

    .co-cat-group {
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .co-cat-group:last-child {
      border-bottom: none;
    }

    .co-cat-group-label {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px 8px;
      font-size: 10px;
      font-weight: 800;
      color: var(--amber);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .co-cat-group-label .cat-emoji {
      font-size: 14px;
    }

    .co-recipe-list {
      padding: 0 18px 10px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .co-recipe-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: var(--cream2);
      padding: 4px 0;
    }

    .co-recipe-item::before {
      content: '▸';
      color: var(--amber);
      font-size: 10px;
      flex-shrink: 0;
    }

    /* ─── MOBILE ─── */
    @media (max-width: 750px) {
      .checkout-grid {
        grid-template-columns: 1fr;
        gap: 0;
      }

      .checkout-right {
        position: static;
        order: -1;
      }

      .checkout-left {
        order: 1;
      }

      .co-form-card {
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      }

      .checkout-page {
        padding: 56px 0 40px;
      }

      .co-left-inner {
        padding: 0 16px;
        margin-top: 16px;
      }

      .co-price-main {
        font-size: 46px;
      }

      .co-headline {
        font-size: 26px;
      }

      /* Hide original catalogue in left column on mobile — shown via mobile clone below */
      .co-catalogue-original {
        display: none;
      }

      /* Show mobile catalogue clone */
      .co-catalogue-mobile {
        display: block;
        margin: 12px 16px 0;
      }

      /* Compress form card height on mobile so catalogue is above the fold */
      .co-secure-row {
        display: none;
      }
      .co-form-body > div[style*="rgba(34,197,94"] {
        display: none;
      }
      .co-form-body > div[style*="text-align:center"] {
        display: none;
      }
      .co-price-note {
        font-size: 11px;
      }
      .co-form-body {
        padding: 16px 16px 12px;
      }
      .co-price-header {
        padding: 12px 16px 10px;
      }
      .co-input-wrap {
        margin-bottom: 10px !important;
      }
      .co-pay-btn {
        padding: 14px;
      }
    }

    @media (min-width: 751px) {
      .co-left-inner {
        padding-top: 8px;
      }
    }
  </style>
</head>

<body>

  <!-- Minimal nav -->
  <nav class="app-nav">
    <div class="app-nav-inner">
      <a href="/" class="app-nav-logo" style="display:flex;align-items:center;gap:8px;">
        <span>The Chai Dealer</span>
        <span style="font-size:11px;color:#7A6050;font-weight:700;letter-spacing:0.06em;">·</span>
        <span style="color:#E8921A;font-weight:800;letter-spacing:0.03em;">CuisineCraft</span>
      </a>
      <div style="display:flex;align-items:center;gap:6px;font-size:12px;font-weight:700;color:var(--muted);">
        🔒 100% Secure Checkout
      </div>
    </div>
  </nav>

  <div class="checkout-page">
    <div class="checkout-grid">

      <!-- ═══ LEFT: Value & proof ═══ -->
      <div class="checkout-left">
        <div class="co-left-inner">

          <div style="margin-bottom:20px;">
            <div class="co-headline">
              You're One Step Away From A <span>Chef-Free Cafe</span>
            </div>
            <p class="co-sub">Join 500+ cafe owners who've locked their taste, cut chef dependency and built a
              consistent menu with 19 SOP video recipes.</p>
          </div>

          <!-- What's included -->
          <div class="co-includes">
            <div class="co-includes-title">✦ Everything You Get Today</div>
            <div class="co-item">
              <span class="co-item-icon">🎬</span>
              <div class="co-item-text">
                <strong>19 SOP Video Recipes</strong>
                <span>Starter · Tea · Maggi · Sandwich · Pasta · Bun · Mojitos</span>
              </div>
            </div>
            <div class="co-item">
              <span class="co-item-icon">⚖️</span>
              <div class="co-item-text">
                <strong>Exact Gram Measurements</strong>
                <span>No guesswork — consistent taste every single time</span>
              </div>
            </div>
            <div class="co-item">
              <span class="co-item-icon">🧮</span>
              <div class="co-item-text">
                <strong>Portion & Costing Calculator</strong>
                <span>Know your exact profit per dish. End waste forever.</span>
              </div>
            </div>
            <div class="co-item">
              <span class="co-item-icon">🖨️</span>
              <div class="co-item-text">
                <strong>Printable Kitchen Playbooks</strong>
                <span>Stick on kitchen wall — staff follows without videos</span>
              </div>
            </div>
            <div class="co-item">
              <span class="co-item-icon">⚡</span>
              <div class="co-item-text">
                <strong>3-Day Staff Training System</strong>
                <span>Any unskilled hire making perfect dishes in 72 hrs</span>
              </div>
            </div>
            <div class="co-item">
              <span class="co-item-icon">♾️</span>
              <div class="co-item-text">
                <strong>Lifetime Access — No Monthly Fees</strong>
                <span>Pay once. Train every new hire for years.</span>
              </div>
            </div>
          </div>

          <!-- Testimonials -->
          <div class="co-testi" id="testiBox">
            <div class="co-testi-stars">★★★★★</div>
            <p class="co-testi-text" id="testiText">"I was paying ₹25k/month to a chef. Trained two helpers in 3 days using these SOPs. Saving lakhs now."</p>
            <div class="co-testi-author">
              <div class="co-testi-avatar" id="testiInitials">MS</div>
              <div>
                <div class="co-testi-name" id="testiName">Mayank Sharma</div>
                <div class="co-testi-role" id="testiRole">Outlet Owner, Mumbai</div>
              </div>
            </div>
          </div>

          <div class="co-testi" style="margin-top:12px;">
            <div class="co-testi-stars">★★★★★</div>
            <p class="co-testi-text">"My chef left during Diwali rush. My helper ran the entire kitchen using the SOPs. Not a single complaint from customers."</p>
            <div class="co-testi-author">
              <div class="co-testi-avatar" style="background:linear-gradient(135deg,#1a3a5c,#3b82f6);color:#fff;">DV</div>
              <div>
                <div class="co-testi-name">Deepak Verma</div>
                <div class="co-testi-role">Cafe Owner, Delhi</div>
              </div>
            </div>
          </div>

          <div class="co-testi" style="margin-top:12px;">
            <div class="co-testi-stars">★★★★★</div>
            <p class="co-testi-text">"Was skeptical about a ₹999 course replacing a ₹25k chef. Three months in — food quality is better and more consistent than before."</p>
            <div class="co-testi-author">
              <div class="co-testi-avatar" style="background:linear-gradient(135deg,#5c1a3a,#ec4899);color:#fff;">KS</div>
              <div>
                <div class="co-testi-name">Kavita Singh</div>
                <div class="co-testi-role">Restaurant Owner, Jaipur</div>
              </div>
            </div>
          </div>

          <!-- Value vs price -->
          <div
            style="background:rgba(34,197,94,0.05);border:1px solid rgba(34,197,94,0.12);border-radius:var(--radius);padding:14px 16px;margin-bottom:16px;">
            <div
              style="font-size:11px;color:var(--muted);font-weight:800;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">
              💰 The Math Is Simple</div>
            <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;">
              <span style="color:var(--cream2);">Chef salary (monthly)</span>
              <span style="color:var(--red-light);font-weight:700;">₹20,000 – ₹30,000</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;">
              <span style="color:var(--cream2);">This SOP system (one-time)</span>
              <span style="color:var(--green);font-weight:700;">₹999</span>
            </div>

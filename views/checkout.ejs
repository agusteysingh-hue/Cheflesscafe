  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    // ─── Countdown Timer ───
    function initCountdown() {
      const key = 'co_deadline';
      let deadline = localStorage.getItem(key);
      if (!deadline || Date.now() > parseInt(deadline)) {
        deadline = Date.now() + (23 * 3600 + 59 * 60 + 59) * 1000;
        localStorage.setItem(key, deadline);
      }
      setInterval(() => {
        const diff = parseInt(deadline) - Date.now();
        if (diff <= 0) { document.getElementById('cdTimer').textContent = '00:00:00'; return; }
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        document.getElementById('cdTimer').textContent =
          String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
      }, 1000);
    }
    initCountdown();

    // ─── Course Catalogue Toggle ───
    function toggleCatalogue() {
      const body = document.getElementById('catBody');
      const chevron = document.getElementById('catChevron');
      const isOpen = body.classList.toggle('open');
      chevron.classList.toggle('open', isOpen);
    }
    function toggleCatalogueMobile() {
      const body = document.getElementById('catBodyMobile');
      const chevron = document.getElementById('catChevronMobile');
      const isOpen = body.classList.toggle('open');
      chevron.classList.toggle('open', isOpen);
    }
    // ─── Rotating Testimonials ───
    const testis = [
      { text: '"I was paying ₹25k/month to a chef. Trained two helpers in 3 days. Saving lakhs now."', init: 'MS', name: 'Mayank Sharma', role: 'Outlet Owner, Mumbai' },
      { text: '"My Zomato rating went from 3.8 to 4.5 in two months. Taste is finally consistent!"', init: 'AJ', name: 'Amit Joshi', role: 'Cloud Kitchen, Hyderabad' },
      { text: '"Chef left during Diwali rush. My helper ran the kitchen alone using the SOPs. Zero complaints."', init: 'DV', name: 'Deepak Verma', role: 'Cafe Owner, Delhi' },
      { text: '"Opened my second outlet with zero stress. Just gave SOPs to new team — ready in 3 days."', init: 'PP', name: 'Priya Patel', role: 'Multi-outlet Owner, Ahmedabad' },
    ];
    let ti = 0;
    setInterval(() => {
      ti = (ti + 1) % testis.length;
      const t = testis[ti];
      const box = document.getElementById('testiBox');
      box.style.opacity = '0';
      setTimeout(() => {
        document.getElementById('testiText').textContent = t.text;
        document.getElementById('testiInitials').textContent = t.init;
        document.getElementById('testiName').textContent = t.name;
        document.getElementById('testiRole').textContent = t.role;
        box.style.transition = 'opacity 0.4s';
        box.style.opacity = '1';
      }, 300);
    }, 5000);

    // ─── Live enrolled count ───
    const counts = ['2 people enrolled today', '3 people enrolled today', '5 people enrolled in the last hour', '1 person just enrolled'];
    document.getElementById('recentCount').textContent = counts[Math.floor(Math.random() * counts.length)];

    // ─── Phone formatting ───
    document.getElementById('coPhone').addEventListener('input', function () {
      this.value = this.value.replace(/\D/g, '').slice(0, 10);
    });

    // ─── Error/loading helpers ───
    function showError(msg) {
      const el = document.getElementById('coError');
      el.textContent = msg;
      el.style.display = 'block';
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
    function clearError() { document.getElementById('coError').style.display = 'none'; }
    function setLoading(on) {
      document.getElementById('payText').style.display = on ? 'none' : 'flex';
      document.getElementById('paySpinner').style.display = on ? 'block' : 'none';
      document.getElementById('payBtn').disabled = on;
    }

    // ─── Payment flow ───
    async function startPayment() {
      // Fire begin_checkout event — wrapped so it never blocks payment
      try {
        gtag('event', 'begin_checkout', {
          value: 999,
          currency: 'INR'
        });
      } catch(e) {}

      clearError();
      const name = document.getElementById('coName').value.trim();
      const email = document.getElementById('coEmail').value.trim();
      const phone = document.getElementById('coPhone').value.trim();

      if (!name) { showError('Please enter your full name.'); return; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('Please enter a valid email address.'); return; }
      if (!phone || !/^\d{10}$/.test(phone)) { showError('Please enter a valid 10-digit WhatsApp number.'); return; }

      setLoading(true);

      try {
        const res = await fetch('/api/create-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, phone }),
        });
        const data = await res.json();

        if (!res.ok) { showError(data.error || 'Something went wrong. Please try again.'); setLoading(false); return; }

        const rzp = new Razorpay({
          key: data.keyId,
          amount: data.amount,
          currency: data.currency,
          name: 'The Chai Dealer',
          description: 'Chefless Cafe Menu System — 19 SOP Videos',
          order_id: data.orderId,
          handler: async (response) => {
            setLoading(true);
            try {
              // 15 second timeout — never spin forever
              const controller = new AbortController();
              const timeout = setTimeout(() => controller.abort(), 15000);

              const vRes = await fetch('/api/verify-payment', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                signal: controller.signal,
                body: JSON.stringify({
                  razorpay_order_id: response.razorpay_order_id,
                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_signature: response.razorpay_signature,
                  name, email, phone,
                }),
              });
              clearTimeout(timeout);
              const result = await vRes.json();
              if (result.success) {
                // Save credentials for Thank You page
                sessionStorage.setItem('waUrl', result.whatsappUrl || '');
                sessionStorage.setItem('userPassword', result.customerPassword || '');
                sessionStorage.setItem('userEmail', email);
                sessionStorage.setItem('userName', name);
                if (result.whatsappUrl) {
                  window.open(result.whatsappUrl, '_blank');
                }
                const tokenParam = result.loginToken ? `?token=${result.loginToken}` : '';
                window.location.href = '/thankyou' + tokenParam;
              } else {
                showError(result.error || 'Verification failed. Contact support.');
                setLoading(false);
              }
            } catch (e) {
              // Payment already done — redirect anyway
              console.error('Verify error:', e);
              window.location.href = '/thankyou';
            }
          },
          prefill: { name, email, contact: '91' + phone },
          theme: { color: '#E8921A' },
          modal: { ondismiss: () => setLoading(false) },
        });
        rzp.open();
        setLoading(false);
      } catch (e) {
        showError('Network error. Please check your connection and try again.');
        setLoading(false);
      }
    }
  </script>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0A0806">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <nav class="app-nav">
    <div class="app-nav-inner">
      <a href="/" class="app-nav-logo">The Chai Dealer</a>
      <div class="app-nav-links">
        <a href="/courses" class="app-nav-link active">Courses</a>
        <a href="/dashboard" class="app-nav-link">Dashboard</a>
        <a href="/logout" class="app-nav-link" style="color:var(--red-light);">Logout</a>
      </div>
    </div>
  </nav>

  <div class="page page-wide">
    <h1 style="font-family:var(--font-display);font-size:clamp(36px,6vw,52px);color:var(--white);margin-bottom:8px;">
      All <span style="color:var(--amber);">Courses</span>
    </h1>
    <p style="color:var(--muted);margin-bottom:32px;font-size:14px;">19 SOP video recipes organized by category. Click any course to start learning.</p>

    <% categoryOrder.forEach(function(catName) {
      const catCourses = categorized[catName];
      if (!catCourses) return;
    %>
      <div class="category-section">
        <h2 class="category-title"><%= catName %></h2>
        <div class="course-grid">
          <% catCourses.forEach(function(c) { %>
            <a href="/course/<%= c.id %>" class="course-card">
              <span class="course-icon"><%= c.icon %></span>
              <div class="course-info">
                <div class="course-name"><%= c.name %></div>
                <div class="course-cat"><%= catName %></div>
              </div>
              <% if (completed.includes(c.id)) { %>
                <span class="course-done">✓</span>
              <% } %>
            </a>
          <% }); %>
        </div>
      </div>
    <% }); %>
  </div>
</body>
</html>

    gtag('config', 'G-TMZ3HQ49BE');
  </script>
  <!-- Meta Pixel Code -->
  <script>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '1262928896031587');
  fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
  src="https://www.facebook.com/tr?id=1262928896031587&ev=PageView&noscript=1"
  /></noscript>
  <!-- End Meta Pixel Code -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0A0806">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <nav class="app-nav">
    <div class="app-nav-inner">
      <a href="/" class="app-nav-logo">The Chai Dealer</a>
      <div class="app-nav-links">
        <a href="/courses" class="app-nav-link">Courses</a>
        <a href="/dashboard" class="app-nav-link active">Dashboard</a>
        <a href="/logout" class="app-nav-link" style="color:var(--red-light);">Logout</a>
      </div>
    </div>
  </nav>

  <div class="page page-wide">
    <!-- Greeting -->
    <div style="margin-bottom:28px;">
      <h1 style="font-family:var(--font-display);font-size:clamp(36px,6vw,52px);color:var(--white);line-height:1;">
        Welcome back, <span style="color:var(--amber);"><%= userName %>!</span>
      </h1>
      <p style="color:var(--muted);margin-top:6px;font-size:14px;">Your SOP training centre. Track progress and access all courses.</p>
    </div>

    <!-- Stats -->
    <div class="dash-stats">
      <div class="dash-stat">
        <div class="dash-stat-value"><%= completedCount %></div>
        <div class="dash-stat-label">Completed</div>
      </div>
      <div class="dash-stat">
        <div class="dash-stat-value"><%= totalCourses - completedCount %></div>
        <div class="dash-stat-label">Remaining</div>
      </div>
      <div class="dash-stat">
        <div class="dash-stat-value"><%= totalCourses %></div>
        <div class="dash-stat-label">Total Courses</div>
      </div>
      <div class="dash-stat">
        <div class="dash-stat-value" style="color:<%= progressPercent === 100 ? 'var(--green)' : 'var(--amber)' %>;"><%= progressPercent %>%</div>
        <div class="dash-stat-label">Progress</div>
      </div>
    </div>

    <!-- Progress bar -->
    <div style="margin-bottom:32px;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span style="font-size:12px;color:var(--muted);font-weight:700;">OVERALL PROGRESS</span>
        <span style="font-size:12px;color:var(--amber);font-weight:700;"><%= completedCount %>/<%= totalCourses %> lessons</span>
      </div>
      <div class="progress-wrap">
        <div class="progress-bar" style="width:<%= progressPercent %>%;"></div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:12px;margin-bottom:36px;">
      <a href="/courses" class="btn-full btn-amber" style="max-width:none;">📚 View All Courses →</a>
      <% if (completedCount < totalCourses) {
        const nextCourse = courses.find(c => true); %>
        <a href="/course/<%= nextCourse.id %>" class="btn-full btn-outline" style="max-width:none;">▶ Continue Learning</a>
      <% } %>
    </div>

    <!-- Recent Courses -->
    <div style="margin-bottom:20px;">
      <h2 style="font-family:var(--font-display);font-size:28px;color:var(--white);margin-bottom:16px;">Your Courses</h2>
      <div class="course-grid">
        <% courses.slice(0, 6).forEach(function(c) { %>
          <a href="/course/<%= c.id %>" class="course-card">
            <span class="course-icon"><%= c.icon %></span>
            <div class="course-info">
              <div class="course-name"><%= c.name %></div>
              <div class="course-cat"><%= c.category %></div>
            </div>
          </a>
        <% }); %>
      </div>
      <% if (courses.length > 6) { %>
        <div style="text-align:center;margin-top:16px;">
          <a href="/courses" style="font-weight:700;font-size:14px;">View all <%= totalCourses %> courses →</a>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
